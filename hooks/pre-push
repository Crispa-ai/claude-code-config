#!/bin/bash
# Pre-push hook - runs CLAUDE.md validation before allowing push
# Installed via: git config core.hooksPath .claude/hooks
# Part of claude-code-config shared configuration

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo ""
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Pre-Push Validation (claude-code-config)${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Get the remote name from positional argument (fallback to "origin")
REMOTE_NAME="${1:-origin}"

# Get current branch
CURRENT_BRANCH=$(git branch --show-current)
REMOTE_BRANCH="$REMOTE_NAME/$CURRENT_BRANCH"

# Temporary file for NUL-delimited file list
FILES_LIST=$(mktemp)
trap 'rm -f "$FILES_LIST"' EXIT

# Get changed files compared to remote (NUL-delimited for safety)
if git rev-parse --verify "$REMOTE_BRANCH" >/dev/null 2>&1; then
    git diff --name-only -z "$REMOTE_BRANCH" HEAD 2>/dev/null > "$FILES_LIST" || true
else
    # New branch - get files from last commit
    git diff --name-only -z HEAD~1 HEAD 2>/dev/null > "$FILES_LIST" || git ls-files -z > "$FILES_LIST"
fi

# Check if any files to validate
if [ ! -s "$FILES_LIST" ]; then
    echo -e "${GREEN}✓${NC} No files to validate"
    exit 0
fi

ERRORS=0
WARNINGS=0

# 1. Check for secrets/tokens
echo -e "${BLUE}1.${NC} Checking for secrets/tokens..."
SECRETS=$(xargs -0 grep -lE '(api_key|secret_key|password|Bearer |sk_live|sk_test|AKIA|ghp_|gho_)' < "$FILES_LIST" 2>/dev/null | grep -v '\.md$' | grep -v 'test' | head -5 || true)
if [ -n "$SECRETS" ]; then
    echo -e "   ${RED}✗${NC} Potential secrets found in:"
    echo "$SECRETS" | sed 's/^/      /'
    ERRORS=$((ERRORS + 1))
else
    echo -e "   ${GREEN}✓${NC} No secrets detected"
fi

# 2. Check for console.log in TypeScript/JavaScript (excluding tests)
echo -e "${BLUE}2.${NC} Checking for console.log..."
JS_FILES_LIST=$(mktemp)
xargs -0 -I{} sh -c 'echo "$1"' _ {} < "$FILES_LIST" 2>/dev/null | grep -E '\.(ts|tsx|js|jsx)$' | grep -v '\.test\.' | grep -v '__tests__' | grep -v '\.spec\.' > "$JS_FILES_LIST" || true
if [ -s "$JS_FILES_LIST" ]; then
    CONSOLE_LOGS=$(xargs grep -n 'console\.log' < "$JS_FILES_LIST" 2>/dev/null | grep -v '// eslint-disable' | head -5 || true)
    if [ -n "$CONSOLE_LOGS" ]; then
        echo -e "   ${RED}✗${NC} console.log found:"
        echo "$CONSOLE_LOGS" | head -3 | sed 's/^/      /'
        ERRORS=$((ERRORS + 1))
    else
        echo -e "   ${GREEN}✓${NC} No console.log found"
    fi
else
    echo -e "   ${GREEN}✓${NC} No JS/TS files changed"
fi
rm -f "$JS_FILES_LIST"

# 3. Check for TypeScript 'any' type
echo -e "${BLUE}3.${NC} Checking for TypeScript 'any' type..."
TS_FILES_LIST=$(mktemp)
xargs -0 -I{} sh -c 'echo "$1"' _ {} < "$FILES_LIST" 2>/dev/null | grep -E '\.(ts|tsx)$' | grep -v '\.d\.ts$' > "$TS_FILES_LIST" || true
if [ -s "$TS_FILES_LIST" ]; then
    ANY_TYPES=$(xargs grep -n ': any\b' < "$TS_FILES_LIST" 2>/dev/null | grep -v '// eslint-disable' | grep -v '\.test\.' | head -5 || true)
    if [ -n "$ANY_TYPES" ]; then
        echo -e "   ${YELLOW}⚠${NC} TypeScript 'any' found (consider proper types):"
        echo "$ANY_TYPES" | head -3 | sed 's/^/      /'
        WARNINGS=$((WARNINGS + 1))
    else
        echo -e "   ${GREEN}✓${NC} No 'any' types found"
    fi
else
    echo -e "   ${GREEN}✓${NC} No TypeScript files changed"
fi
rm -f "$TS_FILES_LIST"

# 4. Check tenant page authentication (Crispa-specific)
echo -e "${BLUE}4.${NC} Checking tenant page authentication..."
TENANT_AUTH_ERRORS=0
while IFS= read -r -d '' page; do
    if [[ "$page" =~ pages/\[tenant\].*\.(tsx|ts)$ ]]; then
        if [ -f "$page" ]; then
            if ! grep -qE 'withAuthenticationRequired|getSession|getServerSideProps' "$page"; then
                echo -e "   ${RED}✗${NC} Missing authentication: $page"
                TENANT_AUTH_ERRORS=$((TENANT_AUTH_ERRORS + 1))
            fi
        fi
    fi
done < "$FILES_LIST"
if [ $TENANT_AUTH_ERRORS -gt 0 ]; then
    ERRORS=$((ERRORS + TENANT_AUTH_ERRORS))
elif xargs -0 -I{} sh -c 'echo "$1"' _ {} < "$FILES_LIST" 2>/dev/null | grep -qE 'pages/\[tenant\].*\.(tsx|ts)$'; then
    echo -e "   ${GREEN}✓${NC} All tenant pages have authentication"
else
    echo -e "   ${GREEN}✓${NC} No tenant pages changed"
fi

# 5. Check for hardcoded IDs
echo -e "${BLUE}5.${NC} Checking for hardcoded IDs..."
HARDCODED=$(xargs -0 grep -nE '(user_id|tenant_id|slack_id|channel_id)\s*=\s*["\x27][A-Za-z0-9_-]{5,}["\x27]' < "$FILES_LIST" 2>/dev/null | grep -v test | grep -v mock | head -3 || true)
if [ -n "$HARDCODED" ]; then
    echo -e "   ${YELLOW}⚠${NC} Potential hardcoded IDs:"
    echo "$HARDCODED" | sed 's/^/      /'
    WARNINGS=$((WARNINGS + 1))
else
    echo -e "   ${GREEN}✓${NC} No hardcoded IDs detected"
fi

# 6. Check for N+1 query patterns (Django)
echo -e "${BLUE}6.${NC} Checking for N+1 query patterns..."
PY_FILES_LIST=$(mktemp)
xargs -0 -I{} sh -c 'echo "$1"' _ {} < "$FILES_LIST" 2>/dev/null | grep -E '\.py$' | grep -v test | grep -v migration > "$PY_FILES_LIST" || true
if [ -s "$PY_FILES_LIST" ]; then
    N_PLUS_1=$(xargs grep -n '\.objects\.' < "$PY_FILES_LIST" 2>/dev/null | grep -v 'select_related\|prefetch_related' | grep 'for.*in.*\.all()\|for.*in.*\.filter(' | head -3 || true)
    if [ -n "$N_PLUS_1" ]; then
        echo -e "   ${YELLOW}⚠${NC} Potential N+1 queries (use select_related/prefetch_related):"
        echo "$N_PLUS_1" | sed 's/^/      /'
        WARNINGS=$((WARNINGS + 1))
    else
        echo -e "   ${GREEN}✓${NC} No obvious N+1 patterns"
    fi
else
    echo -e "   ${GREEN}✓${NC} No Python files changed"
fi
rm -f "$PY_FILES_LIST"

# Summary
echo ""
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}✗ Push blocked: $ERRORS error(s), $WARNINGS warning(s)${NC}"
    echo ""
    echo -e "  Fix errors above, or bypass with: ${YELLOW}git push --no-verify${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠ Passed with $WARNINGS warning(s) - please review${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 0
else
    echo -e "${GREEN}✓ All validations passed${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 0
fi
